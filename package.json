{
  "name": "hnovel",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered long-form novel writing workspace",
  "scripts": {
    "app": "npm run dev",
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "cd web && npm run dev",
    "dev:server": "cd server && npm run dev",
    "build": "npm run build:web && npm run build:server",
    "build:web": "cd web && npm run build",
    "build:server": "cd server && npm run build",
    "start": "npm run build && npm run start:server",
    "start:server": "cd server && npm run start",
    "lint": "npm run lint:web && npm run lint:server",
    "lint:web": "cd web && npm run lint",
    "lint:server": "cd server && npm run build",
    "test": "npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
